#!/bin/bash

# Base path for built apps
# Resolve the true path of this script, even if it's a symlink
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE" # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
done
PROJECT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
BUILD_DIR="${PROJECT_DIR}/build"

IS_PERSISTENT=0
ICON_NAME=""
PASSTHROUGH_ARGS=()

# Parse arguments to find special flags (-persistent, -icon)
# and filter them out from the arguments passed to the binary.
while [[ $# -gt 0 ]]; do
    key="$1"
    case $key in
        -persistent)
            IS_PERSISTENT=1
            shift # past argument
            ;;
        -icon)
            ICON_NAME="$2"
            shift # past argument
            shift # past value
            ;;
        *)
            PASSTHROUGH_ARGS+=("$1")
            shift # past argument
            ;;
    esac
done

# Determine which app to use
if [ "$IS_PERSISTENT" -eq 1 ]; then
    # NotifiPersistent is embedded inside NotifiCLI.app by build.sh
    APP_PATH="${BUILD_DIR}/NotifiCLI.app/Contents/Apps/NotifiPersistent.app/Contents/MacOS/NotifiPersistent"
else
    if [ -n "$ICON_NAME" ]; then
        # Check if user provided a full path to an app (e.g. /Applications/Foo.app)
        if [[ "$ICON_NAME" == *.app* ]]; then
             APP_PATH_ARG="$ICON_NAME"
             # Extract basename without extension (e.g. "Foo")
             BASE_NAME=$(basename "$APP_PATH_ARG" .app)
             # Sanitize name (remove spaces/special chars if needed, but simple whitespace removal is safer for filenames)
             VARIANT_NAME="${BASE_NAME// /}"
        else
             VARIANT_NAME="$ICON_NAME"
             APP_PATH_ARG="" 
        fi

        # Check if specific variant exists inside the main app bundle
        VARIANT_PATH="${BUILD_DIR}/NotifiCLI.app/Contents/Apps/NotifiCLI-${VARIANT_NAME}.app/Contents/MacOS/NotifiCLI-${VARIANT_NAME}"
        
        if [ ! -f "$VARIANT_PATH" ] && [ -n "$APP_PATH_ARG" ]; then
             echo "⚙️  Generating new icon variant for '$VARIANT_NAME'..."
             # Call add-icon.sh to generate it (suppress output to keep it clean?)
             "${PROJECT_DIR}/add-icon.sh" "$APP_PATH_ARG" "$VARIANT_NAME" >/dev/null
        fi

        if [ -f "$VARIANT_PATH" ]; then
            APP_PATH="$VARIANT_PATH"
        else
            # Fallback to default if variant not found
            # echo "Warning: Icon variant '${VARIANT_NAME}' not found. Using default icon." >&2
            APP_PATH="${BUILD_DIR}/NotifiCLI.app/Contents/MacOS/NotifiCLI"
        fi
    else
        APP_PATH="${BUILD_DIR}/NotifiCLI.app/Contents/MacOS/NotifiCLI"
    fi
fi
COMMAND="$APP_PATH"

# Check if app exists
if [ ! -f "$APP_PATH" ]; then
    echo "Error: App executable not found at $APP_PATH"
    echo "Please run build.sh in $PROJECT_DIR to build the project."
    exit 1
fi

# Execute the app with filtered arguments
"$COMMAND" "${PASSTHROUGH_ARGS[@]}"

#!/bin/bash

# Configuration
BASE_DIR="/Users/chrislapointe/Scripts/Antigravity/NotifiCLI"
BUILD_DIR="$BASE_DIR/build"
ICONS_DIR="$BASE_DIR/icons"

# Defaults
APP_VARIANT=""
ICON_APP=""
PERSISTENT=false
HAS_ACTIONS=false
ARGS=()

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -persistent)
            PERSISTENT=true
            shift
            ;;
        -app)
            APP_VARIANT="$2"
            shift 2
            ;;
        -icon)
            ICON_APP="$2"
            shift 2
            ;;
        -actions)
            HAS_ACTIONS=true
            ARGS+=("$1" "$2")
            shift 2
            ;;
        -reply)
            HAS_ACTIONS=true
            ARGS+=("$1" "$2")
            shift 2
            ;;
        -sound)
            SOUND_ARG="$2"
            shift 2
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# If -icon is specified, auto-create variant if needed
if [ -n "$ICON_APP" ]; then
    # Check if it's a shorthand name for an existing variant (e.g., "Terminal" instead of full path)
    SHORTHAND_VARIANT="$BUILD_DIR/NotifiCLI-${ICON_APP}.app"
    if [ -d "$SHORTHAND_VARIANT" ]; then
        # Use existing variant directly
        APP_VARIANT="$ICON_APP"
        VARIANT_APP="$SHORTHAND_VARIANT"
    else
        # Generate variant name from app path (e.g., "/Applications/Slack.app" -> "Slack")
        APP_BASENAME=$(basename "$ICON_APP" .app)
        APP_VARIANT=$(echo "$APP_BASENAME" | tr -d ' ')
        VARIANT_APP="$BUILD_DIR/NotifiCLI-${APP_VARIANT}.app"
    fi
    
    # Auto-create if doesn't exist
    if [ ! -d "$VARIANT_APP" ]; then
        echo "Creating icon variant for $APP_BASENAME..." >&2
        
        # Extract icon
        PLIST="$ICON_APP/Contents/Info.plist"
        if [ ! -f "$PLIST" ]; then
            echo "Error: Invalid app path: $ICON_APP" >&2
            exit 1
        fi
        
        ICON_NAME=$(/usr/libexec/PlistBuddy -c "Print :CFBundleIconFile" "$PLIST" 2>/dev/null || echo "")
        [[ "$ICON_NAME" != *.icns ]] && ICON_NAME="${ICON_NAME}.icns"
        [ -z "$ICON_NAME" ] && ICON_NAME="AppIcon.icns"
        
        ICON_PATH="$ICON_APP/Contents/Resources/$ICON_NAME"
        if [ ! -f "$ICON_PATH" ]; then
            echo "Error: Icon not found in app" >&2
            exit 1
        fi
        
        # Copy icon and build variant inline (faster than calling build.sh)
        mkdir -p "$ICONS_DIR"
        cp "$ICON_PATH" "$ICONS_DIR/${APP_VARIANT}.icns"
        
        # Build just this variant
        CONTENTS_DIR="$VARIANT_APP/Contents"
        mkdir -p "$CONTENTS_DIR/MacOS" "$CONTENTS_DIR/Resources"
        
        sed "s/com.DiggingForDinos.NotifiCLI.v2/com.DiggingForDinos.NotifiCLI.${APP_VARIANT}/" "$BASE_DIR/Info.plist" > "$CONTENTS_DIR/Info.plist"
        cp "$ICON_PATH" "$CONTENTS_DIR/Resources/AppIcon.icns"
        cp "$BUILD_DIR/NotifiCLI.app/Contents/MacOS/NotifiCLI" "$CONTENTS_DIR/MacOS/NotifiCLI-${APP_VARIANT}"
        codesign --force --deep -s - "$VARIANT_APP" 2>/dev/null
        
        # Warm up permissions by opening the app once
        open "$VARIANT_APP" 2>/dev/null &
        sleep 0.5
        
        echo "Created NotifiCLI-${APP_VARIANT}" >&2
    fi
fi

# Determine which app to use
if [ "$PERSISTENT" = true ]; then
    TARGET_APP="$BUILD_DIR/NotifiPersistent.app/Contents/MacOS/NotifiPersistent"
elif [ -n "$APP_VARIANT" ]; then
    VARIANT_APP="$BUILD_DIR/NotifiCLI-${APP_VARIANT}.app/Contents/MacOS/NotifiCLI-${APP_VARIANT}"
    if [ -x "$VARIANT_APP" ]; then
        TARGET_APP="$VARIANT_APP"
    else
        echo "Error: Icon variant '$APP_VARIANT' not found." >&2
        echo "Available variants:" >&2
        for app in "$BUILD_DIR"/NotifiCLI-*.app; do
            [ -d "$app" ] && basename "$app" .app | sed 's/NotifiCLI-/  /'
        done
        exit 1
    fi
else
    TARGET_APP="$BUILD_DIR/NotifiCLI.app/Contents/MacOS/NotifiCLI"
fi

# Handle Sound Injection
if [ -n "$SOUND_ARG" ]; then
    SOUND_PATH=""
    
    # Check if it's a file path
    if [ -f "$SOUND_ARG" ]; then
        SOUND_PATH="$SOUND_ARG"
    elif [ -f "/System/Library/Sounds/${SOUND_ARG}.aiff" ]; then
        SOUND_PATH="/System/Library/Sounds/${SOUND_ARG}.aiff"
    elif [ -f "/Library/Sounds/${SOUND_ARG}.aiff" ]; then
        SOUND_PATH="/Library/Sounds/${SOUND_ARG}.aiff"
    elif [ -f "/System/Library/Sounds/${SOUND_ARG}" ]; then
        SOUND_PATH="/System/Library/Sounds/${SOUND_ARG}"
    fi

    if [ -n "$SOUND_PATH" ]; then
        # Inject the sound file into the app bundle
        APP_BUNDLE="${TARGET_APP%/Contents/*}"
        RESOURCES_DIR="$APP_BUNDLE/Contents/Resources"
        SOUND_FILENAME=$(basename "$SOUND_PATH")
        
        # Copy and re-sign
        cp "$SOUND_PATH" "$RESOURCES_DIR/$SOUND_FILENAME"
        codesign --force --deep -s - "$APP_BUNDLE" 2>/dev/null
        
        FINAL_SOUND_NAME="$SOUND_FILENAME"
    else
        # Assume it's a name we couldn't resolve validly, pass as-is
        FINAL_SOUND_NAME="$SOUND_ARG"
    fi
    
    ARGS+=("-sound" "$FINAL_SOUND_NAME")
fi

# Run the selected app
# If no actions, run in background (fire-and-forget)
# If actions present, wait for user response
if [ "$HAS_ACTIONS" = true ]; then
    "$TARGET_APP" "${ARGS[@]}"
else
    "$TARGET_APP" "${ARGS[@]}" &
fi

#!/bin/bash

# notificli - A wrapper script for NotifiCLI that handles icon variants and path resolution.

# Find our real location even if symlinked
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PROJECT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# Resolve App directory (prefer /Applications for permissions)
if [ -d "/Applications/NotifiCLI.app" ]; then
    APP_DIR="/Applications/NotifiCLI.app"
elif [ -d "${HOME}/Applications/NotifiCLI.app" ]; then
    APP_DIR="${HOME}/Applications/NotifiCLI.app"
else
    APP_DIR="${PROJECT_DIR}/build/NotifiCLI.app"
fi

BUILD_DIR="${PROJECT_DIR}/build" # Keep for auto-generation check

IS_PERSISTENT=0
ICON_NAME=""
PASSTHROUGH_ARGS=()

# Parse arguments to find special flags (-persistent, -icon, -app)
# and handle shorthands for the binary (-t -> -title, -m -> -message)
while [[ $# -gt 0 ]]; do
    key="$1"
    case $key in
        -p|-persistent)
            IS_PERSISTENT=1
            shift # past argument
            ;;
        -i|-icon|-a|-app)
            ICON_NAME="$2"
            shift # past argument
            shift # past value
            ;;
        -t)
            PASSTHROUGH_ARGS+=("-title" "$2")
            shift 2
            ;;
        -m)
            PASSTHROUGH_ARGS+=("-message" "$2")
            shift 2
            ;;
        *)
            PASSTHROUGH_ARGS+=("$1")
            shift # past argument
            ;;
    esac
done

# Resolve variant name if icon is provided
VARIANT_NAME=""
APP_PATH_ARG=""
if [ -n "$ICON_NAME" ]; then
    # If it ends in .app or contains a slash, treat as path
    if [[ "$ICON_NAME" == *.app* ]] || [[ "$ICON_NAME" == */* ]]; then
        APP_PATH_ARG="$ICON_NAME"
    else
        # Otherwise, try common locations
        if [ -d "/Applications/${ICON_NAME}.app" ]; then
            APP_PATH_ARG="/Applications/${ICON_NAME}.app"
        elif [ -d "/System/Applications/${ICON_NAME}.app" ]; then
            APP_PATH_ARG="/System/Applications/${ICON_NAME}.app"
        elif [ -d "/System/Applications/Utilities/${ICON_NAME}.app" ]; then
            APP_PATH_ARG="/System/Applications/Utilities/${ICON_NAME}.app"
        else
            # Default to just the name in /Applications even if not found yet (for error reporting later)
            APP_PATH_ARG="/Applications/${ICON_NAME}.app"
        fi
    fi

    # Final existence check for paths
    if [ ! -d "$APP_PATH_ARG" ] && [[ "$APP_PATH_ARG" != /* ]]; then
         # Try to resolve relative to common apps
         if [ -d "/Applications/$APP_PATH_ARG" ]; then
             APP_PATH_ARG="/Applications/$APP_PATH_ARG"
         fi
    fi

    BASE_NAME=$(basename "$APP_PATH_ARG" .app)
    VARIANT_NAME="${BASE_NAME// /}"
fi

# Determine which app to use
if [ "$IS_PERSISTENT" -eq 1 ]; then
    BASE_APP_NAME="NotifiPersistent"
    DEFAULT_PATH="${APP_DIR}/Contents/Apps/NotifiPersistent.app/Contents/MacOS/NotifiPersistent"
else
    BASE_APP_NAME="NotifiCLI"
    # Use -Binary suffix to avoid conflict with the wrapper script on case-insensitive systems
    DEFAULT_PATH="${APP_DIR}/Contents/MacOS/NotifiCLI-Binary"
fi

APP_PATH="$DEFAULT_PATH"

if [ -n "$VARIANT_NAME" ]; then
    # Binary name inside the variant bundle
    VARIANT_BINARY="${BASE_APP_NAME}-${VARIANT_NAME}"
    
    # Path to the variant binary
    VARIANT_PATH="${APP_DIR}/Contents/Apps/${VARIANT_BINARY}.app/Contents/MacOS/${VARIANT_BINARY}"
    
    # If not found in /Applications, check build dir
    if [ ! -f "$VARIANT_PATH" ]; then
        VARIANT_PATH="${BUILD_DIR}/NotifiCLI.app/Contents/Apps/${VARIANT_BINARY}.app/Contents/MacOS/${VARIANT_BINARY}"
    fi

    # If variant doesn't exist yet, attempt to generate it
    if [ ! -f "$VARIANT_PATH" ]; then
         if [ -n "$APP_PATH_ARG" ]; then
              echo "⚙️  Generating new icon variant for '${BASE_NAME}'..."
              "${PROJECT_DIR}/add-icon.sh" "$APP_PATH_ARG" "$VARIANT_NAME" "$BASE_NAME"
              EXIT_CODE=$?
              if [ $EXIT_CODE -ne 0 ]; then
                  echo "⚠️  Icon generation failed (Code $EXIT_CODE). Falling back to default icon."
              else
                  # Re-resolve after generation, prioritizing /Applications if it was installed there
                  if [ -f "${APP_DIR}/Contents/Apps/${VARIANT_BINARY}.app/Contents/MacOS/${VARIANT_BINARY}" ]; then
                      VARIANT_PATH="${APP_DIR}/Contents/Apps/${VARIANT_BINARY}.app/Contents/MacOS/${VARIANT_BINARY}"
                  else
                      VARIANT_PATH="${BUILD_DIR}/NotifiCLI.app/Contents/Apps/${VARIANT_BINARY}.app/Contents/MacOS/${VARIANT_BINARY}"
                  fi
                  
                  # BLESSING STEP for Tahoe/Sequoia: Force registration and visible launch
                  VARIANT_APP=$(dirname "$(dirname "$(dirname "$VARIANT_PATH")")")
                  if [ -d "$VARIANT_APP" ]; then
                      /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f "$VARIANT_APP"
                      # Foreground launch helps trigger the prompt on macOS 16 (Tahoe)
                      open "$VARIANT_APP" 2>/dev/null || true
                  fi
              fi
         fi
    fi

    # Final existence check
    if [ -f "$VARIANT_PATH" ]; then
        APP_PATH="$VARIANT_PATH"
        VARIANT_APP=$(dirname "$(dirname "$(dirname "$VARIANT_PATH")")")
    fi
fi

COMMAND="$APP_PATH"

# Check if app exists
if [ ! -f "$APP_PATH" ]; then
    echo "Error: App executable not found at $APP_PATH"
    echo "Please run build.sh in $PROJECT_DIR to build the project."
    exit 1
fi

# Execute the app with filtered arguments
OUTPUT=$("$COMMAND" "${PASSTHROUGH_ARGS[@]}" 2>&1)
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ] && [[ "$OUTPUT" == *"Notifications are not allowed"* ]]; then
    # Determine the bundle and name for permission request
    if [ -n "$VARIANT_APP" ]; then
        TARGET_BUNDLE="$VARIANT_APP"
        if [ "$IS_PERSISTENT" -eq 1 ]; then
            FRIENDLY_NAME="${BASE_NAME} (Persistent)"
        else
            FRIENDLY_NAME="${BASE_NAME}"
        fi
    else
        # For base app, we need to target the bundle that owns the notifications
        if [ "$IS_PERSISTENT" -eq 1 ]; then
            FRIENDLY_NAME="NotifiCLI (Persistent)"
            # Persistent base app is in Contents/Apps/
            if [ -d "${APP_DIR}/Contents/Apps/NotifiPersistent.app" ]; then
                TARGET_BUNDLE="${APP_DIR}/Contents/Apps/NotifiPersistent.app"
            else
                TARGET_BUNDLE="$APP_DIR"
            fi
        else
            FRIENDLY_NAME="NotifiCLI"
            TARGET_BUNDLE="$APP_DIR"
        fi
    fi

    echo "⚙️  Notification permission missing for '${FRIENDLY_NAME}'. Requesting authorization..."
    
    # Re-trigger blessing: register with LaunchServices and open to prompt authorization
    # Use absolute path for lsregister
    /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f "$TARGET_BUNDLE"
    # For newer macOS, opening the bundle usually triggers the prompt
    open "$TARGET_BUNDLE" 2>/dev/null || true
    
    echo ""
    echo "💡 A permission prompt should appear. If not, enable notifications manually:"
    echo "   System Settings > Notifications > ${FRIENDLY_NAME}"
    echo ""
    echo "Then re-run your command."
    exit $EXIT_CODE
elif [ $EXIT_CODE -ne 0 ]; then
    echo "$OUTPUT"
    exit $EXIT_CODE
else
    echo "$OUTPUT"
fi
